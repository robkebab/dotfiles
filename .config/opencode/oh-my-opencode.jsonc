{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Orchestrators need top reasoning
    "sisyphus": {
      "model": "vercel/anthropic/claude-opus-4.6"
    },
    "prometheus": {
      "model": "vercel/anthropic/claude-opus-4.6"
    },
    "oracle": {
      "model": "vercel/anthropic/claude-opus-4.6"
    },
    // Autonomous deep worker for goal-oriented tasks
    "hephaestus": {
      "model": "vercel/openai/gpt-5.2-codex"
    },
    // Workers need good balance of cost and capability
    "atlas": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "librarian": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "explore": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "metis": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "momus": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    // Multimodal tasks go to the best vision model per dollar
    "multimodal-looker": {
      "model": "vercel/google/gemini-3-flash"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "vercel/google/gemini-3-flash"
    },
    "ultrabrain": {
      "model": "vercel/anthropic/claude-opus-4.6"
    },
    "deep": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "artistry": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    },
    "quick": {
      "model": "vercel/anthropic/claude-haiku-4.5"
    },
    "unspecified-low": {
      "model": "vercel/anthropic/claude-haiku-4.5"
    },
    "unspecified-high": {
      "model": "vercel/anthropic/claude-opus-4.6"
    },
    "writing": {
      "model": "vercel/anthropic/claude-sonnet-4.6"
    }
  }
}
