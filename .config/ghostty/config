title = robkebab
config-default-files = false
maximize = true
quit-after-last-window-closed-delay = 30s
clipboard-read = allow
window-padding-x = 14
window-padding-y = 5
theme = Vercel
background = #101010
foreground = #fafafa
selection-background = #005be7
selection-foreground = #fafafa
cursor-color = #f32882
cursor-text = #fafafa
font-family = GeistMono NF
macos-icon = retro
keybind = ctrl+d=scroll_page_lines:1 
keybind = ctrl+u=scroll_page_lines:-1 
keybind = shift+]=scroll_page_lines:10
keybind = shift+[=scroll_page_lines:-10
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right
keybind = global:super+backquote=toggle_quick_terminal
